{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "project": "fam-mail",
  "description": "Email-to-postcard service with React frontend and Bun backend",
  "model": "claude-sonnet-4-6",
  "commands": {
    "test": "cd backend && bun test && cd ../frontend && npx vitest run",
    "lint": "cd backend && pnpm lint && cd ../frontend && pnpm lint",
    "build": "cd frontend && pnpm build"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(npx:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
