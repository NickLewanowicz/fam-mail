# Nightshift environment variables
# These are loaded automatically when nightshift runs from this project.
# Values here do NOT override existing environment variables.

# ZAI API Key for GLM model access
# ZAI_API_KEY=your-key-here

# ZAI API base URL (optional, defaults to api.z.ai)
# ZAI_API_BASE=https://api.z.ai

# GitHub token (optional, uses `gh auth token` if not set)
# GITHUB_TOKEN=ghp_...
